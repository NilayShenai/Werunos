<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>werunos</id>
    <version>1.8.5</version>
    <title>Werunos</title>
    <authors>NilayShenai</authors>
    <projectUrl>https://github.com/NilayShenai/Werunos</projectUrl>
    <licenseUrl>https://github.com/NilayShenai/Werunos/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/NilayShenai/Werunos</projectSourceUrl>
    <tags>ext4 btrfs windows winfsp userspace filesystem driver</tags>
    <summary>Lightweight userspace Ext4 and Btrfs filesystem driver for Windows via WinFsp.</summary>
    <description>
      Werunos is a lightweight userspace Ext4 and Btrfs filesystem driver for Windows powered by WinFsp.
      It allows you to natively mount Linux partitions and raw disk images with full POSIX-compliant read-write support,
      supporting advanced structures such as multi-depth extent trees, recursive B-Tree index node splitting, extended attributes (xattrs),
      transparent compression (zlib, LZO, ZSTD), and crash-safe transaction logging.
    </description>
    <dependencies>
      <dependency id="winfsp" version="1.12.22339" />
    </dependencies>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
